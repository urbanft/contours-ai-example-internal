<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <ScrollView
        android:id="@+id/content_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="@dimen/space_16"
        android:paddingTop="@dimen/space_24"
        android:paddingEnd="@dimen/space_16"
        android:paddingBottom="@dimen/space_120"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|center_horizontal"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/hero_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_16"
                android:background="@drawable/bg_hero_card"
                android:elevation="10dp"
                android:orientation="vertical"
                android:padding="@dimen/space_24">

                <TextView
                    android:id="@+id/tv_eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/check_scan"
                    android:textColor="@color/text_strong"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_version_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.04"
                    android:text="@string/powered_by_native_android"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_screen_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:fontFamily="sans-serif-light"
                    android:text="@string/check_scan"
                    android:textColor="@color/text_strong"
                    android:textSize="34sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_screen_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/check_description"
                    android:textColor="@color/text_muted"
                    android:textSize="15sp" />

                <LinearLayout
                    android:id="@+id/preview_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/front_preview_tile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_download_front"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/space_8"
                            android:text="@string/front_check"
                            android:textColor="@color/text_strong"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <FrameLayout
                            android:id="@+id/front_preview_wrap"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_preview_tile">

                            <ImageView
                                android:id="@+id/iv_front"
                                android:layout_width="match_parent"
                                android:layout_height="220dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tv_front"
                                android:layout_width="match_parent"
                                android:layout_height="220dp"
                                android:gravity="center"
                                android:padding="@dimen/space_12"
                                android:text="@string/front_check"
                                android:textAlignment="center"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/back_preview_tile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_download_back"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/space_8"
                            android:text="@string/back_check"
                            android:textColor="@color/text_strong"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <FrameLayout
                            android:id="@+id/back_preview_wrap"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_preview_tile">

                            <ImageView
                                android:id="@+id/iv_back"
                                android:layout_width="match_parent"
                                android:layout_height="220dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tv_back"
                                android:layout_width="match_parent"
                                android:layout_height="220dp"
                                android:gravity="center"
                                android:padding="@dimen/space_12"
                                android:text="@string/back_check"
                                android:textAlignment="center"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_tabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_16"
        android:layout_marginEnd="@dimen/space_16"
        android:layout_marginBottom="@dimen/space_24"
        android:background="@drawable/bg_bottom_tabs"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:padding="@dimen/space_8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/check"
            style="@style/TabButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="@string/check" />

        <TextView
            android:id="@+id/id"
            style="@style/TabButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="@string/id" />

        <TextView
            android:id="@+id/passport"
            style="@style/TabButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="@string/passport" />

        <TextView
            android:id="@+id/selfie"
            style="@style/TabButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="@string/selfie" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
